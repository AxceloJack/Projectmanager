// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String?
  owner     User?    @relation("owned_workspaces", fields: [ownerId], references: [id], onDelete: SetNull)
  currency  String   @default("GBP") // display currency for the finance tracker
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clients            Client[]
  slackIntegrations  SlackIntegration[]
  financeEntries     FinanceEntry[]

  @@map("workspaces")
}

model FinanceEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  date        DateTime // one-off date, or first occurrence if recurring
  description String
  category    String?
  type        String    @default("EXPENSE") // INCOME | EXPENSE
  amount      Float
  fee         Float     @default(0) // service/processing fee in `currency`, always deducted
  currency    String    @default("GBP") // currency this entry was paid/spent in
  status      String    @default("PAID") // PAID | PENDING
  recurring   Boolean   @default(false)
  frequency   String? // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  endDate     DateTime? // optional last occurrence for recurring entries
  fxRate      Float? // base value of 1 unit of `currency`, frozen at the entry date
  fxBase      String? // base currency the fxRate was frozen against
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([clientId])
  @@map("finance_entries")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role         String   @default("MEMBER")
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedWorkspaces Workspace[] @relation("owned_workspaces")
  tasks           Task[]      @relation("assigned_to")
  taskComments    TaskComment[]

  @@index([workspaceId])
  @@map("users")
}

model Client {
  id                    String   @id @default(cuid())
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                  String
  email                 String?
  publicKey             String   @unique @default(cuid())
  serviceType           String   @default("FLOW_ONLY")
  kickOffDate           DateTime?
  klaviyoBillingDate    DateTime?
  slackId               String?
  slackUserId           String?
  klaviyoApi            String?
  figmaLink             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tasks          Task[]
  campaigns      Campaign[]
  campaignForms  CampaignForm[]
  financeEntries FinanceEntry[]

  @@index([workspaceId])
  @@map("clients")
}

model CampaignForm {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type         String    @default("CAMPAIGN") // CAMPAIGN | ONBOARDING
  month        String? // YYYY-MM the strategy is planned for (campaign only)
  publicKey    String    @unique @default(cuid())
  status       String    @default("PENDING") // PENDING | SUBMITTED

  // Campaign strategy answers
  sales        String?
  launches     String?
  specialDates String?
  avoidances   String?
  notes        String?

  // Onboarding answers
  brandOverview  String?
  targetAudience String?
  brandVoice     String?
  goals          String?
  currentSetup   String?
  keyProducts    String?
  links          String?
  inspiration    String?

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@map("campaign_forms")
}

model Task {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  dueDate         DateTime
  status          String   @default("NOT_STARTED")
  tag             String   @default("FLOW")
  assigneeId      String?
  assignee        User?    @relation("assigned_to", fields: [assigneeId], references: [id], onDelete: SetNull)
  figmaLink       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments TaskComment[]

  @@index([clientId])
  @@index([assigneeId])
  @@index([dueDate])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
  @@map("task_comments")
}

model Campaign {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  sendDate  DateTime?
  status    String   @default("draft")
  metrics   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  abTests ABTest[]

  @@index([clientId])
  @@map("campaigns")
}

model ABTest {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  variantA   String
  variantB   String
  winner     String?
  results    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([campaignId])
  @@map("ab_tests")
}

model SlackIntegration {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String
  botToken    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, teamId])
  @@index([workspaceId])
  @@map("slack_integrations")
}
